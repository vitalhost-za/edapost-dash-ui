# Database (Supabase PostgreSQL - direct connection)
DATABASE_URL=postgresql://postgres.[PROJECT_ID]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# JWT (Supabase JWT secret for validating auth tokens)
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# API Server
API_PORT=3001
API_HOST=0.0.0.0

# Worker
WORKER_CONCURRENCY=5
WORKER_BATCH_SIZE=20
WORKER_POLL_INTERVAL_MS=5000

# SMTP defaults (Postfix on localhost)
SMTP_HOST=127.0.0.1
SMTP_PORT=25
